# Copy this file to scripts/email-sync.env on the server that runs the sync
# job, then restrict its permissions (chmod 600).
#
# Use the SERVICE ROLE key (not the anon/publishable key) so the script can
# bypass RLS and call decrypt_email_password.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
