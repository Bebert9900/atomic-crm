POSTMARK_WEBHOOK_USER=
POSTMARK_WEBHOOK_PASSWORD=
VITE_INBOUND_EMAIL=

# IPs: https://postmarkapp.com/support/article/800-ips-for-firewalls#webhooks
POSTMARK_WEBHOOK_AUTHORIZED_IPS=

SB_JWT_ISSUER=http://127.0.0.1:54321/auth/v1
SB_PUBLISHABLE_KEY=

# Optional: Gemini for audio transcription (transcribe_recording)
GEMINI_API_KEY=

# --- Agentic (agent-runtime) ---
# At least one LLM provider key is required to run skills that use an LLM.
# Routing is automatic based on the skill manifest `model` prefix:
#   claude-*   -> ANTHROPIC_API_KEY
#   deepseek-* -> DEEPSEEK_API_KEY

# Anthropic (claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5-20251001)
ANTHROPIC_API_KEY=

# DeepSeek (deepseek-chat, deepseek-reasoner)
DEEPSEEK_API_KEY=
# Optional override (e.g. internal proxy). Defaults to https://api.deepseek.com
DEEPSEEK_BASE_URL=
